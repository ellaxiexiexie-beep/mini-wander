<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Mini Wander — a Code Boutique</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&display=swap" rel="stylesheet">
<style>
:root{--green:#324434;--yellow:#ffa61e;--greyGreen:#afbead;--dark:#141414;--header-h:64px;--ease:cubic-bezier(.87,0,.13,1)}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;-webkit-font-smoothing:antialiased}
body{font-family:"Helvetica Neue",Helvetica,Arial,sans-serif;background:var(--green);color:var(--yellow);overflow-x:hidden;line-height:1.4}
a{color:inherit;text-decoration:none}

body{cursor:none}
#cursor-dot{position:fixed;top:0;left:0;width:10px;height:10px;background:var(--yellow);border-radius:50%;z-index:9999;pointer-events:none;mix-blend-mode:difference;transition:width .2s,height .2s}
#cursor-ring{position:fixed;top:0;left:0;width:34px;height:34px;border:1.5px solid rgba(255,166,30,.45);border-radius:50%;z-index:9998;pointer-events:none;transition:width .25s,height .25s}
#cursor-dot.hover{width:20px;height:20px;background:#ffe545}
#cursor-ring.hover{width:50px;height:50px;border-color:#ffe545}
@media(max-width:768px){#cursor-dot,#cursor-ring{display:none}body{cursor:auto}}

#noise{position:fixed;inset:0;z-index:5;pointer-events:none;opacity:.035;background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");background-repeat:repeat;background-size:200px 200px}

#curtain{position:fixed;inset:0;z-index:100;background:var(--yellow);transform:translateY(-100%);transition:transform .7s var(--ease);display:flex;align-items:center;justify-content:center;pointer-events:none}
#curtain.show{transform:translateY(0);pointer-events:all}
#curtain .wordmark{width:80px;color:var(--green);animation:curtainSpin .6s var(--ease)}
@keyframes curtainSpin{from{transform:rotate(-90deg);opacity:0}to{transform:rotate(0);opacity:1}}

#header{position:fixed;top:0;left:0;width:100%;height:var(--header-h);z-index:50;display:flex;align-items:center;justify-content:space-between;padding:0 2.5rem;color:var(--yellow);mix-blend-mode:difference;transition:background .35s}
#header.scrolled{background:rgba(50,68,52,.9);backdrop-filter:blur(12px);mix-blend-mode:normal}
#logo{width:108px;height:20px}
#nav{display:flex;gap:2.2rem}
#nav a{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;font-weight:600;position:relative;cursor:none}
#nav a::after{content:"";position:absolute;left:0;bottom:-4px;width:100%;height:1px;background:currentColor;transform:scaleX(0);transform-origin:left;transition:transform .3s ease}
#nav a:hover::after,#nav a.active::after{transform:scaleX(1)}
#menu-btn{display:none;background:none;border:none;cursor:none;z-index:55}
#menu-btn span{display:block;width:24px;height:2px;background:var(--yellow);margin:5px 0;transition:.3s}
@media(max-width:768px){#nav{display:none}#menu-btn{display:block}#nav.open{display:flex;flex-direction:column;position:absolute;top:var(--header-h);left:0;width:100%;background:var(--green);padding:2rem;gap:1.5rem;z-index:49}}

#hero{position:fixed;top:0;left:0;width:100%;height:100vh;height:100dvh;overflow:hidden;z-index:1}
@keyframes heroBreath{0%,100%{transform:scale(1)}50%{transform:scale(1.015)}}
#hero-bg{position:absolute;top:-15%;left:-15%;width:130%;height:130%;transform-style:preserve-3d;will-change:transform;animation:heroBreath 6s ease-in-out infinite}

#hero-video-a,#hero-video-b{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
#hero-video-a{opacity:0;z-index:0} /* hidden, drawn to canvas */
#hero-video-b{opacity:0;z-index:0}

#hero-fx{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:2}
#hero::after{content:"";position:absolute;inset:0;background:radial-gradient(ellipse at center,transparent 50%,rgba(10,12,8,.6));pointer-events:none;z-index:3}
#hero-hint{position:absolute;bottom:3rem;left:50%;transform:translateX(-50%);z-index:10;font-size:.65rem;text-transform:uppercase;letter-spacing:.15em;color:var(--yellow);opacity:.8;pointer-events:none;transition:opacity .8s ease}
#hero-hint.gone{opacity:0}
#hero-text{position:absolute;bottom:4rem;left:50%;transform:translateX(-50%);z-index:10;pointer-events:none;transition:opacity .8s ease,transform .3s;text-align:center}
#hero-text .eyebrow{font-size:clamp(1.4rem,4vw,2.4rem);text-transform:none;letter-spacing:.04em;margin-bottom:0;opacity:.9;font-weight:400;font-family:"Playfair Display",serif;font-style:italic}
#hero-text h1{font-family:"Playfair Display",serif;font-size:clamp(2rem,5vw,3.8rem);font-weight:700;line-height:1.12}
#hero-text h1 em{font-style:italic;font-weight:400}
#hero-text p{font-size:.8rem;line-height:1.65;opacity:.75;margin-top:.8rem;max-width:400px;color:var(--greyGreen)}
#hero-text.hidden{opacity:0;pointer-events:none}

#hero-spacer{height:105vh}
#main{position:relative;z-index:3;background:var(--green);padding:5rem 2.5rem 8rem}
@media(max-width:768px){#main{padding:3rem 1.5rem 6rem}}
.sec-label{font-size:.6rem;text-transform:uppercase;letter-spacing:.14em;color:var(--greyGreen);font-weight:600;margin-bottom:.2rem}
.sec-title{font-family:"Playfair Display",serif;font-size:clamp(2.2rem,5vw,4.2rem);font-weight:700;line-height:1.1;margin-bottom:3rem}
.sec-title em{font-style:italic;font-weight:400}
#cases,#work-cases{display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;margin-bottom:5rem}
@media(max-width:768px){#cases,#work-cases{grid-template-columns:1fr}}
.case{position:relative;overflow:hidden;border-radius:6px;aspect-ratio:4/3;background:var(--dark);cursor:none;transition:transform .4s var(--ease)}
.case:hover{transform:translateY(-6px)}
.case img{width:100%;height:100%;object-fit:cover;transition:transform .6s var(--ease)}
.case:hover img{transform:scale(1.04)}
.case .info{position:absolute;bottom:0;left:0;width:100%;padding:2.5rem 1.8rem 1.8rem;background:linear-gradient(transparent,rgba(0,0,0,.75));color:#fff}
.case .client{font-size:.55rem;text-transform:uppercase;letter-spacing:.1em;opacity:.7;margin-bottom:.25rem}
.case .name{font-family:"Playfair Display",serif;font-size:1.2rem;font-weight:700;margin-bottom:.3rem}
.case .desc{font-size:.72rem;opacity:.8;line-height:1.45}
#clients{display:flex;flex-wrap:wrap;gap:1.5rem 3rem;align-items:center;justify-content:center;padding:4rem 0;margin-bottom:5rem;border-top:1px solid rgba(255,166,30,.15);border-bottom:1px solid rgba(255,166,30,.15)}
#clients span{font-size:.7rem;text-transform:uppercase;letter-spacing:.1em;color:var(--greyGreen);font-weight:600}
#expertise,#work-expertise{display:grid;grid-template-columns:repeat(3,1fr);gap:2.5rem;margin-bottom:5rem}
@media(max-width:768px){#expertise,#work-expertise{grid-template-columns:1fr}}
.exp-card{padding:2rem 0;border-top:1px solid rgba(255,166,30,.2);transition:border-color .3s}
.exp-card:hover{border-top-color:var(--yellow)}
.exp-num{font-size:.58rem;color:var(--greyGreen);letter-spacing:.1em;margin-bottom:.7rem}
.exp-title{font-family:"Playfair Display",serif;font-size:1.3rem;font-weight:700;margin-bottom:.5rem}
.exp-desc{font-size:.76rem;color:var(--greyGreen);line-height:1.6}
#footer{display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;padding:4rem 0 2rem;border-top:1px solid rgba(255,166,30,.15)}
@media(max-width:768px){#footer{grid-template-columns:1fr}}
#footer h4{font-size:.6rem;text-transform:uppercase;letter-spacing:.12em;color:var(--greyGreen);margin-bottom:1rem}
#footer a,#footer p{font-size:.76rem;line-height:2;display:block;transition:opacity .2s}
#footer a:hover{opacity:.55}
#footer .bottom{grid-column:1/-1;text-align:center;padding-top:3rem;font-size:.62rem;color:var(--greyGreen);display:flex;gap:2rem;justify-content:center;flex-wrap:wrap}
#footer .bottom a{color:var(--greyGreen)}#footer .bottom a:hover{color:var(--yellow)}
.reveal{opacity:0;transform:translateY(28px);transition:opacity .7s var(--ease),transform .7s var(--ease)}
.reveal.on{opacity:1;transform:translateY(0)}
.d1{transition-delay:.1s}.d2{transition-delay:.2s}.d3{transition-delay:.3s}
.page{display:none}.page.show{display:block}
.about-page{padding-top:.5rem}
#page-about.show #main{padding-top:2rem;padding-bottom:3rem}
.about-page h2{font-family:"Playfair Display",serif;font-size:clamp(1.8rem,3.5vw,3rem);font-weight:700;line-height:1.25;margin-bottom:.5rem}
.about-page h2 em{font-style:italic;font-weight:400}
/* Work page */
.work-page{padding-top:.5rem}
.work-page .sec-title{margin-bottom:1.5rem}
/* ═══════════ Wave Gallery — frosted-glass polaroids on water ═══════════ */
.memory-gallery{padding:.3rem 0 0;overflow:visible}
.wave-stage{position:relative;min-height:550px;overflow:visible}
@media(max-width:768px){.wave-stage{min-height:400px}}

/* ── Card ── */
.wave-card{position:absolute;cursor:none;z-index:1;transition:opacity .6s var(--ease),filter .6s var(--ease)}
.wave-card.dimmed{opacity:.1;filter:grayscale(70%) blur(2px);pointer-events:none}
.wave-card.centered{z-index:20}
.wave-card.centered .card-inner{transform:scale(1.65)}
@media(max-width:768px){.wave-card.centered .card-inner{transform:scale(1.3)}}

/* ── 3D flip ── */
.card-inner{position:relative;width:100%;height:100%;transform-style:preserve-3d;perspective:1400px;transition:transform .85s cubic-bezier(.25,1.2,.5,1),scale .7s var(--ease)}
.wave-card.flipped .card-inner{transform:rotateY(180deg) scale(1.65)}
@media(max-width:768px){.wave-card.flipped .card-inner{transform:rotateY(180deg) scale(1.3)}}

/* ── Front — frosted glass polaroid ── */
.card-front,.card-back{position:absolute;inset:0;backface-visibility:hidden;-webkit-backface-visibility:hidden;border-radius:8px;overflow:hidden}
.card-front{display:flex;flex-direction:column;
  background:linear-gradient(150deg,rgba(255,255,255,.14) 0%,rgba(255,255,255,.04) 45%,rgba(255,255,255,.08) 100%);
  backdrop-filter:blur(22px) saturate(1.3);-webkit-backdrop-filter:blur(22px) saturate(1.3);
  border:1.5px solid rgba(255,255,255,.15);
  box-shadow:0 8px 36px rgba(0,0,0,.32),inset 0 1px 0 rgba(255,255,255,.1);
  padding:8px 8px 0 8px;transition:border-color .6s,box-shadow .6s}
.card-front::after{content:"";position:absolute;inset:0;border-radius:8px;pointer-events:none;z-index:5;
  background:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
  opacity:.45;mix-blend-mode:overlay}
.card-front-img{flex:1;overflow:hidden;border-radius:4px;position:relative;z-index:1}
.card-front-img img{width:100%;height:100%;object-fit:cover;opacity:.45;filter:grayscale(18%);transition:all 1.4s var(--ease)}
.wave-card:hover .card-front-img img,.wave-card.centered .card-front-img img,.wave-card.flipped .card-front-img img{opacity:1;filter:none}
.card-shimmer{position:absolute;inset:8px 8px 0 8px;border-radius:4px;z-index:3;opacity:0;pointer-events:none;
  background:linear-gradient(135deg,transparent 30%,rgba(255,166,30,.1) 50%,transparent 70%);background-size:200% 200%}
.wave-card.flipped .card-shimmer{opacity:1;animation:shimmerSweep 2s ease-in-out infinite}
@keyframes shimmerSweep{0%{background-position:200% 200%}100%{background-position:-200% -200%}}
.card-label{padding:12px 6px 10px;text-align:center;position:relative;z-index:2}
.card-label .cl-year{display:block;font-size:.65rem;font-weight:700;color:var(--yellow);opacity:.45;letter-spacing:.08em;transition:opacity .5s}
.card-label .cl-name{display:block;font-size:.55rem;color:var(--greyGreen);margin-top:3px;text-transform:uppercase;letter-spacing:.1em;transition:color .5s}
.wave-card.centered .cl-year,.wave-card.flipped .cl-year{opacity:1}
.wave-card.centered .cl-name,.wave-card.flipped .cl-name{color:var(--yellow)}

/* ── Back ── */
.card-back{transform:rotateY(180deg);display:flex;flex-direction:column;
  background:rgba(16,18,16,.99);backdrop-filter:blur(36px);-webkit-backdrop-filter:blur(36px);
  border:1.5px solid rgba(255,166,30,.4);
  box-shadow:0 0 60px rgba(255,166,30,.2),inset 0 0 50px rgba(255,166,30,.05);
  padding:14px;overflow-y:auto;scrollbar-width:none;-ms-overflow-style:none}
.card-back .cb-title{font-family:"Playfair Display",serif;font-size:.95rem;font-weight:700;color:var(--yellow);margin-bottom:4px}
.card-back .cb-year{font-size:.5rem;margin-bottom:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--greyGreen);margin-bottom:14px;display:block;opacity:.7}
.card-back .cb-summary{font-size:.6rem;color:var(--greyGreen);line-height:1.7;margin-bottom:10px;padding-bottom:10px;border-bottom:1px solid rgba(255,166,30,.1)}
.card-back .cb-detail{font-size:.56rem;color:var(--greyGreen);line-height:1.75}
.card-back .cb-detail p{margin-bottom:4px}
.card-back .cb-detail p strong{color:var(--yellow);opacity:.85}
.card-back::-webkit-scrollbar{display:none}
.card-back .cb-hint{font-size:.45rem;padding-top:8px;color:rgba(175,190,173,.3);margin-top:auto;padding-top:10px;text-align:center;letter-spacing:.06em}

/* ── Sizes ── */
.wave-card{width:230px;min-height:307px}
.wave-card:nth-child(3){width:265px;min-height:353px}
@media(max-width:768px){.wave-card{width:150px;min-height:200px}.wave-card:nth-child(3){width:180px;min-height:240px}}

/* ── Divider ── */
.magic-divider{display:flex;align-items:center;justify-content:center;margin:.8rem 0 0}
.magic-divider span{display:block;width:60%;max-width:300px;height:1px;background:linear-gradient(90deg,transparent,rgba(255,166,30,.35),transparent);position:relative}
.magic-divider span::after{content:"";position:absolute;top:-2px;left:50%;transform:translateX(-50%);width:6px;height:6px;border-radius:50%;background:var(--yellow);box-shadow:0 0 12px rgba(255,166,30,.6)}

/* ═══════════ Creek Timeline — flowing stream ═══════════ */
.creek-wrap{position:relative;max-width:720px;margin:1.2rem auto 0;padding:0 2rem;height:70px;overflow:visible}
@media(max-width:768px){.creek-wrap{max-width:100%;padding:0 1rem;height:55px}}

/* The stream line — subtle flowing water */
.creek-line{position:absolute;left:2rem;right:2rem;top:14px;height:3px;border-radius:2px;
  background:linear-gradient(90deg,
    rgba(175,190,173,.06),rgba(175,190,173,.12),rgba(255,166,30,.08),rgba(175,190,173,.12),rgba(175,190,173,.06));
  overflow:hidden}
.creek-line::after{content:"";position:absolute;inset:0;
  background:linear-gradient(90deg,transparent 30%,rgba(255,166,30,.15) 45%,rgba(255,200,120,.08) 50%,rgba(255,166,30,.15) 55%,transparent 70%);
  background-size:200% 100%;
  animation:creekFlow 4s linear infinite}
@keyframes creekFlow{0%{background-position:200% 0}100%{background-position:-200% 0}}

/* Markers along the stream */
.creek-markers{position:absolute;left:2rem;right:2rem;top:6px;display:flex;justify-content:space-between;padding:0 3%}
.creek-marker{position:relative;display:flex;flex-direction:column;align-items:center;transition:all .5s var(--ease)}
.creek-marker .cm-dot{width:4px;height:4px;border-radius:50%;background:rgba(175,190,173,.15);transition:all 1.4s var(--ease)}
.creek-marker.active .cm-dot{width:7px;height:7px;background:var(--yellow);box-shadow:0 0 14px rgba(255,166,30,.6)}

/* Year label — rises from the stream */
.creek-marker .cm-year{position:absolute;top:12px;white-space:nowrap;font-size:.55rem;font-weight:700;color:var(--yellow);letter-spacing:.06em;
  opacity:0;transform:translateY(8px);transition:opacity .5s var(--ease),transform .5s var(--ease)}
.creek-marker.active .cm-year{opacity:1;transform:translateY(0)}

/* Gliding light spot — moves to active marker */
.creek-glide{position:absolute;top:-3px;width:12px;height:12px;border-radius:50%;
  background:radial-gradient(circle,rgba(255,166,30,.9) 0%,rgba(255,166,30,.2) 50%,transparent 70%);
  box-shadow:0 0 20px rgba(255,166,30,.5),0 0 40px rgba(255,166,30,.15);
  transition:left .8s cubic-bezier(.25,.8,.25,1.2);z-index:5;pointer-events:none;
  opacity:0}
.creek-glide.visible{opacity:1}

@media(max-width:768px){
  .creek-line{top:16px;height:2px}.creek-markers{top:8px}
  .creek-marker .cm-dot{width:3px;height:3px}
  .creek-marker.active .cm-dot{width:5px;height:5px}
  .creek-marker .cm-year{font-size:.48rem;top:10px}
  .creek-glide{width:10px;height:10px;top:-2px}
}

.footer-quote{font-family:"Playfair Display",serif;font-style:italic;font-size:.85rem;color:var(--yellow);opacity:.7;margin-bottom:.8rem;letter-spacing:.02em}
.footer-icons{display:flex;gap:1.2rem;justify-content:center}
.footer-icons a{color:var(--greyGreen);transition:color .3s}
.footer-icons a:hover{color:var(--yellow)}
.contact-page{padding-top:2rem;max-width:600px}
.contact-page h2{font-family:"Playfair Display",serif;font-size:clamp(1.8rem,3.5vw,3rem);font-weight:700;margin-bottom:2.5rem}
.contact-page h2 em{font-style:italic;font-weight:400}
.contact-links{display:flex;flex-direction:column;gap:1.5rem}
.contact-item{display:flex;align-items:center;gap:1rem;padding:1.2rem 1.5rem;border:1px solid rgba(255,166,30,.15);border-radius:8px;transition:border-color .3s,background .3s;cursor:none}
.contact-item:hover{border-color:var(--yellow);background:rgba(255,166,30,.06)}
.contact-item svg{flex-shrink:0;color:var(--yellow)}
.contact-item span{font-size:.9rem;color:var(--greyGreen);transition:color .3s}
.contact-item:hover span{color:var(--yellow)}
</style>
</head>
<body>

<div id="cursor-dot"></div>
<div id="cursor-ring"></div>
<div id="noise"></div>

<div id="curtain">
  <svg class="wordmark" viewBox="0 0 108 20" fill="currentColor"><path d="M4.5 20c-2 0-4-1-4-4V4c0-3 2-4.5 4.5-4.5h7C15 0 17 1.5 17 4.5v4L12 14v2c0 3-2 4-4.5 4H4.5ZM13 4.5C13 3 12 2 10.5 2h-6C3 2 2.5 3 2.5 4.5v11C2.5 17 3 17.5 4.5 17.5h3c1 0 2-.5 2-2v-3l5-5V4.5ZM24 0h-2.5L28 20h2.5L24 0Zm14 0L31.5 20h2.5L40.5 0H38Zm16.5 20h2l-6.5-20h-2l6.5 20Zm16 0-6.5-20h-2l6 18.5V0h-2v20h2.5l2-6h5l2 6H94Zm-3.5-8h4l-2-6-2 6Zm14 8h2l-4-20h-2.5L96.5 20h2l1.5-8h5.5l1.5 8Z"/></svg>
</div>

<header id="header">
  <a href="#" onclick="go('home');return false">
    <svg id="logo" viewBox="0 0 108 20" fill="currentColor"><path d="M4.5 20c-2 0-4-1-4-4V4c0-3 2-4.5 4.5-4.5h7C15 0 17 1.5 17 4.5v4L12 14v2c0 3-2 4-4.5 4H4.5ZM13 4.5C13 3 12 2 10.5 2h-6C3 2 2.5 3 2.5 4.5v11C2.5 17 3 17.5 4.5 17.5h3c1 0 2-.5 2-2v-3l5-5V4.5ZM24 0h-2.5L28 20h2.5L24 0Zm14 0L31.5 20h2.5L40.5 0H38Zm16.5 20h2l-6.5-20h-2l6.5 20Zm16 0-6.5-20h-2l6 18.5V0h-2v20h2.5l2-6h5l2 6H94Zm-3.5-8h4l-2-6-2 6Zm14 8h2l-4-20h-2.5L96.5 20h2l1.5-8h5.5l1.5 8Z"/></svg>
  </a>
  <nav id="nav">
    <a href="#" data-p="home" class="active" onclick="go('home');return false">Explore</a>
    <a href="#" data-p="work" onclick="go('work');return false">Work</a>
    <a href="#" data-p="about" onclick="go('about');return false">About</a>
    <a href="#" data-p="contact" onclick="go('contact');return false">Contact</a>
  </nav>
  <button id="menu-btn" onclick="toggleMenu()"><span></span><span></span><span></span></button>
</header>

<section id="hero">
  <div id="hero-bg">
    <video id="hero-video-a" src="video-1.mp4" muted playsinline preload="auto"></video>
    <video id="hero-video-b" src="video-2.mp4" muted playsinline preload="auto"></video>
    <canvas id="hero-fx"></canvas>
  </div>
  <div id="hero-hint">Click to continue</div>
  <div id="hero-text">
    <div class="eyebrow">mini wander</div>
  </div>
</section>
<div id="hero-spacer"></div>

<main id="main">
  <div class="page show" id="page-home">
    <div class="sec-label reveal">Portfolio</div>
    <div class="sec-title reveal">What I've <em>Built</em></div>
