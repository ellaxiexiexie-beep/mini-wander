<script>
const $=id=>document.getElementById(id);
const A=$('hero-video-a'),B=$('hero-video-b');
const heroBg=$('hero-bg'),hint=$('hero-hint'),heroText=$('hero-text'),curtain=$('curtain');
const dot=$('cursor-dot'),ring=$('cursor-ring'),header=$('header'),nav=$('nav');
const fxCanvas=$('hero-fx'),fxCtx=fxCanvas.getContext('2d');

let unlocked=false;
let curtainDone=false;
let watchEndFn=null;let curtainT1=null,curtainT2=null;let curtainActive=false;

// ===== NATIVE VIDEO LOOP: timeupdate seek at d-0.5, no canvas =====
// MP4 seeks fast enough that skipping 2 draw calls isn't needed.
// Show native video A directly.
A.style.opacity='1';A.style.zIndex='1';
A.play().catch(()=>{});

A.loop=true;

// ===== FX CANVAS =====
function resizeFx(){
  const dpr=devicePixelRatio||1;
  const w=Math.round(innerWidth*1.3),h=Math.round(innerHeight*1.3);
  fxCanvas.width=w*dpr;fxCanvas.height=h*dpr;
  fxCanvas.style.width=w+'px';fxCanvas.style.height=h+'px';
  fxCtx.setTransform(dpr,0,0,dpr,0,0);
}
resizeFx();addEventListener('resize',resizeFx);

// ===== CLICK: load video-2.mov, switch =====
function doSwitch(e){
  if(e&&e.target.closest&&e.target.closest('#header,#nav'))return;
  if(unlocked||cur!=='home')return;
  unlocked=true;
  hint.classList.add('gone');
  heroText.style.transition='opacity 0s';heroText.classList.add('hidden');heroText.style.opacity='0';
  console.log('🔓 Switching to video 2');

  // Stop loop, hide A
  A.loop=false;A.pause();
  A.style.opacity='0';A.style.zIndex='0';

  // Show & play B
  B.style.opacity='1';B.style.zIndex='1';
  B.play().catch(()=>{});

  function watchEnd(){
    const d=B.duration;
    if(!d||!isFinite(d))return;
    if(B.currentTime>=d-0.3){
      B.removeEventListener('timeupdate',watchEnd);
      triggerCurtain();
    }
  }
  B.addEventListener('timeupdate',watchEnd);
  watchEndFn=watchEnd;
}
document.addEventListener('click',doSwitch);
document.addEventListener('touchstart',doSwitch,{once:true});

// ===== CURTAIN → ABOUT =====
function triggerCurtain(){
  if(curtainDone)return;curtainDone=true;
  console.log('🟡 Curtain → About');
  go('about');
}

// ===== PARTICLES =====
const PARTICLES=55;let particles=[];
function spawnParticle(){
  const cw=Math.round(innerWidth*1.3),ch=Math.round(innerHeight*1.3);
  return{x:Math.random()*cw,y:Math.random()*ch,vx:(Math.random()-.5)*.35,vy:(Math.random()-.5)*.25-.15,r:Math.random()*2.5+.8,life:1,decay:.002+Math.random()*.004,hue:Math.random()<.4?40:30+Math.random()*15,sat:70+Math.random()*30,light:55+Math.random()*40};
}
for(let i=0;i<PARTICLES;i++)particles.push(spawnParticle());
function drawParticles(){
  const cw=Math.round(innerWidth*1.3),ch=Math.round(innerHeight*1.3);
  fxCtx.clearRect(0,0,cw,ch);
  const waterTop=ch*.7,breath=Math.sin(performance.now()/1000*1.2)*.5+.5;
  const g=fxCtx.createLinearGradient(0,waterTop,0,ch);
  g.addColorStop(0,'rgba(255,180,40,0)');
  g.addColorStop(.15,`rgba(255,166,30,${.03+.02*breath})`);
  g.addColorStop(.4,`rgba(255,140,20,${.06+.03*breath})`);
  g.addColorStop(.7,`rgba(255,120,15,${.08+.04*breath})`);
  g.addColorStop(1,`rgba(255,100,10,${.04+.02*breath})`);
  fxCtx.fillStyle=g;fxCtx.fillRect(0,waterTop,cw,ch-waterTop);
  for(let i=0;i<particles.length;i++){
    const p=particles[i];p.x+=p.vx;p.y+=p.vy;p.life-=p.decay;
    if(p.life<=0)particles[i]=spawnParticle();
    const r=fxCtx.createRadialGradient(p.x,p.y,0,p.x,p.y,p.r*3);
    r.addColorStop(0,`hsla(${p.hue},${p.sat}%,${p.light}%,${p.life*.9})`);
    r.addColorStop(.4,`hsla(${p.hue},${p.sat}%,${p.light}%,${p.life*.35})`);
    r.addColorStop(1,`hsla(${p.hue},${p.sat}%,${p.light}%,0)`);
    fxCtx.fillStyle=r;fxCtx.beginPath();fxCtx.arc(p.x,p.y,p.r*3,0,Math.PI*2);fxCtx.fill();
    fxCtx.fillStyle=`hsla(${p.hue},${p.sat}%,${p.light+15}%,${p.life*.85})`;
    fxCtx.beginPath();fxCtx.arc(p.x,p.y,p.r,0,Math.PI*2);fxCtx.fill();
  }
  requestAnimationFrame(drawParticles);
}
drawParticles();

// ===== CURSOR =====
let mx=innerWidth/2,my=innerHeight/2,dx=mx,dy=my,rx=mx,ry=my;
addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY});
function animCursor(){
  dx+=(mx-dx)*.35;dy+=(my-dy)*.35;rx+=(mx-rx)*.12;ry+=(my-ry)*.12;
  dot.style.transform=`translate(${dx}px,${dy}px) translate(-50%,-50%)`;
  ring.style.transform=`translate(${rx}px,${ry}px) translate(-50%,-50%)`;
  requestAnimationFrame(animCursor);
}
animCursor();
document.querySelectorAll('a,button,.case,#menu-btn').forEach(el=>{
  el.addEventListener('mouseenter',()=>{dot.classList.add('hover');ring.classList.add('hover')});
  el.addEventListener('mouseleave',()=>{dot.classList.remove('hover');ring.classList.remove('hover')});
});

// ===== 3D PARALLAX =====
let rY=0,rX=0;
function parallax3D(){
  const cx=innerWidth/2,cy=innerHeight/2;
  rY+=(((mx-cx)/cx)*3.5-rY)*.06;rX+=(((cy-my)/cy)*2-rX)*.06;
  heroBg.style.transform=`rotateY(${rY}deg) rotateX(${rX}deg)`;
  heroText.style.transform=`translate(calc(-50% + ${((mx-cx)/cx)*-18}px),${((my-cy)/cy)*-12}px)`;
  requestAnimationFrame(parallax3D);
}
parallax3D();

// ===== NAVIGATION =====
let cur='home';
function updateNavActive(p){
  document.querySelectorAll('#nav a').forEach(a=>a.classList.remove('active'));
  const l=document.querySelector(`#nav a[data-p="${p}"]`);if(l)l.classList.add('active');
}
function switchPage(p){
  document.querySelectorAll('.page').forEach(el=>el.classList.remove('show'));
  const tgt=$('page-'+p);if(tgt)tgt.classList.add('show');
  updateHeroVisibility(p==='home');
}
function resetHome(){
  clearTimeout(curtainT1);clearTimeout(curtainT2);
  if(watchEndFn){B.removeEventListener('timeupdate',watchEndFn);watchEndFn=null;}
  unlocked=false;curtainDone=false;
  hint.classList.remove('gone');
  heroText.style.transition='';heroText.classList.remove('hidden');heroText.style.opacity='';
  B.pause();
  B.currentTime=0;
  B.style.opacity='0';B.style.zIndex='0';
  A.loop=true;A.style.opacity='1';A.style.zIndex='1';
  A.currentTime=0;A.play().catch(()=>{});
}

function updateHeroVisibility(show){
  const hero=document.getElementById('hero');
  const spacer=document.getElementById('hero-spacer');
  if(!hero||!spacer)return;
  hero.style.display=show?'':'none';
  spacer.style.display=show?'':'none';
}
window.go=function(p){
  if(p===cur||curtainActive)return;
  if(p==='home'){resetHome();updateNavActive('home');switchPage('home');scrollTo({top:0,behavior:'smooth'});cur='home';updateHeroVisibility(true);setTimeout(revealCheck,600);return;}
    curtainActive=true;
  curtain.classList.add('show');
  curtainT1=setTimeout(()=>{
    if(!curtainActive){curtainActive=false;return;}
    cur=p;updateNavActive(p);switchPage(p);
    revealCheck();
    curtainT2=setTimeout(()=>{
      if(!curtainActive){curtainActive=false;return;}
      curtain.style.transform='translateY(100%)';
      setTimeout(()=>{curtain.classList.remove('show');curtain.style.transform='translateY(-100%)';curtainDone=true;curtainActive=false;window.scrollTo(0,0);},700);
    },800);
  },500);
};
function revealCheck(){
  document.querySelectorAll('.reveal').forEach(el=>{if(el.getBoundingClientRect().top<innerHeight*.85)el.classList.add('on');});
}
addEventListener('scroll',revealCheck,{passive:true});revealCheck();
addEventListener('scroll',()=>{header.classList.toggle('scrolled',scrollY>50);if(!heroText.classList.contains('hidden'))heroText.style.opacity=Math.max(0,1-scrollY/500);},{passive:true});
// scroll up to hero → reset to video A + home page
addEventListener('scroll',()=>{
  if(scrollY<150&&unlocked&&curtainDone&&cur==='home'){
    resetHome();cur='home';
    updateNavActive('home');switchPage('home');
    scrollTo({top:0,behavior:'instant'});
  }
},{passive:true});
window.toggleMenu=()=>nav.classList.toggle('open');

// ===== RENDER =====
$('cases').innerHTML=$('work-cases').innerHTML=[
  {c:'浙股集团',n:'园区招商管理 SaaS',d:'从零搭建轻量级招商管理系统，项目池+拓展池双模块，状态自动流转，风险智能预警',img:'screenshot-zhaoshang.png'},
  {c:'Codex Skills',n:'AI 技能工具箱',d:'vedic 占星系列、report-helper、小红书助手、notion 会议纪要等 30+ 个可复用技能',img:'hero-poster.jpg'},
  {c:'浙股集团',n:'园区产业分析与产业链图谱',d:'常山/上虞园区产业研究，60+企业分层分类，补链方向识别',img:'hero-poster.jpg'},
  {c:'浙股集团',n:'银行精准获客方案',d:'统筹 6 家银行标准化线上对接流程，推动资产数字化招商',img:'hero-poster.jpg'},
  {c:'个人项目',n:'个人作品集网站',d:'就是你现在看到的这个页面 — 自己设计、自己开发、用 AI 工具独立交付',img:'hero-poster.jpg'},
  {c:'天识科技 / 物产中大',n:'跨境选品与供应链研究',d:'100+企业、500+货品匹配，全球竞品分析与成本结构研究',img:'hero-poster.jpg'},
].map((x,i)=>`<div class="case reveal d${Math.min(i,3)}"><img src="${x.img}" alt="${x.n}" loading="lazy"><div class="info"><div class="client">${x.c}</div><div class="name">${x.n}</div><div class="desc">${x.d}</div></div></div>`).join('');

$('expertise').innerHTML=$('work-expertise').innerHTML=[
  {t:'AI-Native 开发',d:'用 ChatGPT / Codex / WorkBuddy 从需求到交付，独立完成从前端到业务逻辑的全链路开发。'},
  {t:'产品思维',d:'能识别真实痛点、翻译成产品方案。招商系统的业务规则和状态机设计全部来自一线运营经验。'},
  {t:'产业分析',d:'产业链图谱构建、企业分层分类、补链方向识别。用数据支撑精准招商决策。'},
  {t:'跨境运营',d:'海外硕士背景 + 跨境企业实操经验。英语流利，能独立完成国际业务对接。'},
  {t:'金融基础',d:'CFA Level 1 Candidate。能读懂财务报表、理解商业模式和成本结构。'},
  {t:'个人品牌建设',d:'不满足于做执行。用作品集网站、AI 技能工具箱持续输出，建立可感知的个人能力标签。'},
].map((x,i)=>`<div class="exp-card reveal d${Math.min(i,3)}"><div class="exp-num">0${i+1}</div><div class="exp-title">${x.t}</div><div class="exp-desc">${x.d}</div></div>`).join('');

setTimeout(revealCheck,500);

// ═══════════ WATER WAVE + FLIP + CENTER + CREEK TIMELINE ═══════════
let activeMemory=-1,waveRAF=null,centerAnim=null;
const CARD_POSITIONS={};

// ──── Wave positioning ────
function positionWaveCards(forceAll){
  const stage=document.getElementById('wave-stage');
  if(!stage)return;
  const cards=stage.querySelectorAll('.wave-card');
  if(!cards.length)return;
  const n=cards.length,ww=stage.clientWidth,stageH=stage.clientHeight;
  const t=performance.now()/1000,speed=.4,amp=22,freq=.6;
  const isMobile=ww<768;
  const cw=isMobile?150:230,ch=isMobile?200:307;
  const ccw=isMobile?180:265,cch=isMobile?240:353;
  const gap=isMobile?8:18;
  const totalW=(n-2)*cw+2*ccw+(n-1)*gap;
  const startX=(ww-totalW)/2;
  for(let i=0;i<n;i++){
    const w=(i===2)?ccw:cw,h=(i===2)?cch:ch;
    let x=startX;for(let j=0;j<i;j++)x+=(j===2?ccw:cw)+gap;
    const phase=t*speed+i/(n-1)*Math.PI*freq*2;
    const y=(stageH-h)/2+Math.sin(phase)*amp+(i===2?-20:0);
    const key='idx'+i;
    if(forceAll||!(key in CARD_POSITIONS))CARD_POSITIONS[key]={x,y,w,h};
    if(!cards[i].classList.contains('centered')&&!cards[i].classList.contains('dimmed')){
      cards[i].style.left=x+'px';cards[i].style.top=y+'px';
      cards[i].style.width=w+'px';cards[i].style.height=h+'px';
    }
    if(!cards[i].classList.contains('centered'))CARD_POSITIONS[key]={x,y,w,h};
  }
}
function startWave(){
  function loop(){positionWaveCards();waveRAF=requestAnimationFrame(loop);}
  if(waveRAF)cancelAnimationFrame(waveRAF);
  waveRAF=requestAnimationFrame(loop);
}

// ──── Animate card to center ────
function animateToCenter(card,targetX,targetY,targetW,targetH,duration,callback){
  const startL=parseFloat(card.style.left),startT=parseFloat(card.style.top);
  const startW=parseFloat(card.style.width),startH=parseFloat(card.style.height);
  const startTime=performance.now();
  function step(now){
    const p=Math.min((now-startTime)/duration,1);
    const e=1-Math.pow(1-p,3);
    card.style.left=(startL+(targetX-startL)*e)+'px';
    card.style.top=(startT+(targetY-startT)*e)+'px';
    card.style.width=(startW+(targetW-startW)*e)+'px';
    card.style.height=(startH+(targetH-startH)*e)+'px';
    if(p<1)centerAnim=requestAnimationFrame(step);
    else{if(callback)callback();}
  }
  centerAnim=requestAnimationFrame(step);
}

// ──── Creek timeline ────
function highlightCreek(idx){
  const markers=document.querySelectorAll('.creek-marker');
  const glide=document.getElementById('creek-glide');
  if(!markers.length)return;

  // Deactivate all
  markers.forEach(m=>m.classList.remove('active'));

  if(idx<0){
    glide.classList.remove('visible');
    return;
  }

  // Activate target marker
  const target=markers[idx];
  target.classList.add('active');

  // Position glide light at target
  const targetRect=target.getBoundingClientRect();
  const wrap=document.getElementById('creek-wrap');
  const wrapRect=wrap.getBoundingClientRect();
  const glideLeft=targetRect.left-wrapRect.left+targetRect.width/2-6;

  glide.style.left=glideLeft+'px';
  glide.classList.add('visible');
}

// ──── Flip card ────
function flipCard(idx){
  const stage=document.getElementById('wave-stage');
  const cards=stage?stage.querySelectorAll('.wave-card'):document.querySelectorAll('.wave-card');
  if(!cards.length)return;

  // Deselect same card
  if(activeMemory===idx){
    const card=cards[idx];
    card.classList.remove('flipped','centered');
    cards.forEach(c=>c.classList.remove('dimmed'));
    activeMemory=-1;
    highlightCreek(-1);
    const pos=CARD_POSITIONS['idx'+idx];
    if(pos){
      if(centerAnim)cancelAnimationFrame(centerAnim);
      animateToCenter(card,pos.x,pos.y,pos.w,pos.h,500,()=>{startWave();});
    }
    return;
  }

  // Unflip previous
  if(activeMemory>=0){
    cards[activeMemory].classList.remove('flipped','centered');
  }

  activeMemory=idx;
  const card=cards[idx];
  cards.forEach((c,i)=>{if(i!==idx)c.classList.add('dimmed');else c.classList.remove('dimmed');});

  const stageRect=stage.getBoundingClientRect();
  const isMobile=window.innerWidth<768;
  const cw=isMobile?150:230,ch=isMobile?200:307;
  const ccw=isMobile?180:265,cch=isMobile?240:353;
  const tw=(idx===2)?ccw:cw,th=(idx===2)?cch:ch;
  const targetX=(stageRect.width-tw)/2,targetY=Math.max(0,(stageRect.height-th)/2-10);

  if(waveRAF){cancelAnimationFrame(waveRAF);waveRAF=null;}
  if(centerAnim)cancelAnimationFrame(centerAnim);

  // Glide the creek light
  highlightCreek(idx);

  animateToCenter(card,targetX,targetY,tw,th,600,()=>{
    card.classList.add('centered');
    setTimeout(()=>card.classList.add('flipped'),900);
  });
}
window.flipCard=flipCard;

// ──── Click outside to unflip ────
document.addEventListener('click',function(e){
  if(activeMemory<0)return;
  const card=document.querySelector('.wave-card[data-idx="'+activeMemory+'"]');
  if(!card)return;
  if(!card.contains(e.target))flipCard(activeMemory);
});

// ──── About page lifecycle ────
const aboutPg=document.getElementById('page-about');
if(aboutPg){
  const obs=new MutationObserver(()=>{
    if(aboutPg.classList.contains('show')){
      setTimeout(()=>{positionWaveCards(true);startWave();},500);
    }else{
      if(waveRAF){cancelAnimationFrame(waveRAF);waveRAF=null;}
      if(centerAnim){cancelAnimationFrame(centerAnim);centerAnim=null;}
      activeMemory=-1;
    }
  });
  obs.observe(aboutPg,{attributes:true,attributeFilter:['class']});
}

let resizeTimer;
window.addEventListener('resize',()=>{
  clearTimeout(resizeTimer);
  resizeTimer=setTimeout(()=>{
    if(aboutPg&&aboutPg.classList.contains('show')&&activeMemory<0)positionWaveCards(true);
  },250);
});

</script>

</body>
</html>
